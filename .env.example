# JustEats Backend Environment Configuration
# Copy this file to .env and update the values

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=JustEats
DEBUG=true

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection string (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/justeats

# =============================================================================
# Security Settings
# =============================================================================
# JWT signing key - MUST be changed in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-use-secrets-token-urlsafe

# JWT algorithm (default: HS256)
ALGORITHM=HS256

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CORS Configuration
# =============================================================================
# Allowed origins (JSON array format)
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# =============================================================================
# Email Configuration (for password reset)
# =============================================================================
# Leave empty to disable email sending (reset tokens will be logged in DEBUG mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@justeats.com

# =============================================================================
# Business Rules
# =============================================================================
# Minimum order count for "Mostly Ordered" badge
MOSTLY_ORDERED_THRESHOLD=10
