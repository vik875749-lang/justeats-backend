# JustEats Backend Environment Configuration
# Copy this file to .env and update the values

# =============================================================================
# Application Settings
# =============================================================================

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection string (async driver)

# =============================================================================
# Security Settings
# =============================================================================
# JWT signing key - MUST be changed in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"

# Token expiration times

# =============================================================================
# CORS Configuration
# =============================================================================
# Allowed origins (JSON array format)

# =============================================================================
# Email Configuration (for password reset)
# =============================================================================
# Leave empty to disable email sending (reset tokens will be logged in DEBUG mode)

# =============================================================================
# Business Rules
# =============================================================================
# Minimum order count for "Mostly Ordered" badge
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@justeats.com

MOSTLY_ORDERED_THRESHOLD=10
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
SECRET_KEY=change-me-in-production-use-secrets-token-urlsafe

ALGORITHM=HS256
DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/justeats
APP_NAME=JustEats
DEBUG=true